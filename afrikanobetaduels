-- ══════════════════════════════════════════════════════════════
--  WAYPOINT SYSTEM
-- ══════════════════════════════════════════════════════════════

local function ensureFolder()
    if markerFolder and markerFolder.Parent then return end
    markerFolder = Instance.new("Folder")
    markerFolder.Name = "RestDuels_Markers"
    markerFolder.Parent = workspace
end

local function createMarker(pos, index)
    ensureFolder()
    local part = Instance.new("Part")
    part.Name          = "WP_" .. index
    part.Size          = Vector3.new(Config.WaypointSize, Config.WaypointSize, Config.WaypointSize)
    part.Shape         = Enum.PartType.Ball
    part.Material      = Enum.Material.Neon
    part.Color         = Config.WaypointColor
    part.Anchored      = true
    part.CanCollide    = false
    part.CastShadow    = false
    part.CFrame        = CFrame.new(pos)
    part.Parent        = markerFolder

    -- Floating label
    local bg = Instance.new("BillboardGui", part)
    bg.Size            = UDim2.new(0, 40, 0, 20)
    bg.AlwaysOnTop     = true
    bg.StudsOffset     = Vector3.new(0, 1.8, 0)
    local lbl = Instance.new("TextLabel", bg)
    lbl.Size           = UDim2.fromScale(1, 1)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3     = Color3.fromRGB(255, 220, 0)
    lbl.TextScaled     = true
    lbl.Font           = Enum.Font.GothamBold
    lbl.Text           = "#" .. index
    return part
end

local function addWaypoint(pos)
    local idx = #waypoints + 1
    local marker = createMarker(pos, idx)
    table.insert(waypoints, { position = pos, marker = marker })
    return idx
end

local function clearWaypoints()
    for _, wp in ipairs(waypoints) do
        if wp.marker and wp.marker.Parent then
            wp.marker:Destroy()
        end
    end
    waypoints = {}
end

local function highlightWaypoint(idx, active)
    local wp = waypoints[idx]
    if not wp or not wp.marker then return end
    wp.marker.Color = active and Config.ActiveColor or Config.WaypointColor
    wp.marker.Size  = active
        and Vector3.new(Config.WaypointSize * 1.6, Config.WaypointSize * 1.6, Config.WaypointSize * 1.6)
        or  Vector3.new(Config.WaypointSize, Config.WaypointSize, Config.WaypointSize)
end

-- ══════════════════════════════════════════════════════════════
--  AUTOPLAY CORE
-- ══════════════════════════════════════════════════════════════

local function travelTo(targetPos)
    if not Config.AutoWalk then return end
    local dist   = (HRP.Position - targetPos).Magnitude
    local steps  = math.max(1, math.floor(dist / (Config.Speed * 0.05)))
    local origin = HRP.Position

    for i = 1, steps do
        if not isRunning then return false end
        local alpha = i / steps
        HRP.CFrame = CFrame.new(origin:Lerp(targetPos, alpha))
        task.wait(0.05)
    end
    HRP.CFrame = CFrame.new(targetPos)
    return true
end

local function fireGrab()
    -- Fire RE/StealService/Grab with the nearest grabbable target
    -- Adjust args to match the game's expected parameters
    local target = nil
    local minDist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local d = (HRP.Position - hrp.Position).Magnitude
                if d < minDist then
                    minDist = d
                    target  = p.Character
                end
            end
        end
    end

    if target then
        GrabRemote:FireServer(target)
    else
        GrabRemote:FireServer()
    end
end

local function autoplay()
    if isRunning then return end
    if #waypoints == 0 then
        warn("[RestDuels] No waypoints set!")
        return
    end

    isRunning = true

    runThread = task.spawn(function()
        repeat
            for idx, wp in ipairs(waypoints) do
                if not isRunning then break end

                highlightWaypoint(idx, true)

                -- Travel
                local ok = travelTo(wp.position)
                task.wait(0.05)

                -- Fire at last waypoint
                if ok ~= false and idx == #waypoints then
                    task.wait(Config.FireDelay)
                    if isRunning then
                        fireGrab()
                    end
                end

                highlightWaypoint(idx, false)
                task.wait(0.1)
            end
        until not isRunning or not Config.LoopAutoplay

        isRunning = false
    end)
end

local function stopAutoplay()
    isRunning = false
    if runThread then
        task.cancel(runThread)
        runThread = nil
    end
    -- Reset all markers
    for i = 1, #waypoints do
        highlightWaypoint(i, false)
    end
end

