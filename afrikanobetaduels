local function corner(r, p) local c=Instance.new("UICorner",p) c.CornerRadius=UDim.new(0,r) end
local function stroke(t, c2, p) local s=Instance.new("UIStroke",p) s.Thickness=t s.Color=c2 end
local function padding(a,b,c3,d,p)
    local pad=Instance.new("UIPadding",p)
    pad.PaddingTop=UDim.new(0,a) pad.PaddingBottom=UDim.new(0,b)
    pad.PaddingLeft=UDim.new(0,c3) pad.PaddingRight=UDim.new(0,d)
