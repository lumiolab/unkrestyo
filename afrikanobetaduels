local function gradient(c1, c2, rot, p)
    local g = Instance.new("UIGradient", p)
    g.Color    = ColorSequence.new(c1, c2)
    g.Rotation = rot
end

local function label(txt, size, color, font, parent)
    local l = Instance.new("TextLabel", parent)
    l.BackgroundTransparency = 1
    l.Text      = txt
    l.TextSize  = size
    l.TextColor3= color
    l.Font      = font or Enum.Font.GothamBold
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.AutomaticSize  = Enum.AutomaticSize.XY
    return l
end

local function makeButton(txt, parent, bgColor)
    local btn = Instance.new("TextButton", parent)
    btn.Size             = UDim2.new(1, 0, 0, 34)
    btn.BackgroundColor3 = bgColor or C.yellow
    btn.TextColor3       = Color3.fromRGB(15,15,15)
    btn.Text             = txt
    btn.TextSize         = 13
    btn.Font             = Enum.Font.GothamBold
    btn.AutoButtonColor  = false
    corner(8, btn)

    -- Hover effect
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {
            BackgroundColor3 = Color3.fromRGB(255,225,60)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {
            BackgroundColor3 = bgColor or C.yellow
        }):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.06), {
            Size = UDim2.new(1,-4,0,32)
        }):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.06), {
            Size = UDim2.new(1,0,0,34)
        }):Play()
    end)
