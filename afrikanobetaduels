    local track = Instance.new("Frame", row)
    track.Size           = UDim2.new(1,0,0,6)
    track.Position       = UDim2.new(0,0,0,26)
    track.BackgroundColor3 = C.border
    track.BorderSizePixel = 0
    corner(3, track)

    local fill = Instance.new("Frame", track)
    fill.Size            = UDim2.new((current-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = C.yellow
    fill.BorderSizePixel  = 0
    corner(3, fill)

    local nub = Instance.new("TextButton", track)
    nub.Size             = UDim2.new(0,14,0,14)
    nub.Position         = UDim2.new((current-min)/(max-min),0,0.5,-7)
    nub.AnchorPoint      = Vector2.new(0.5,0)
    nub.BackgroundColor3 = C.yellow
    nub.Text             = ""
    nub.AutoButtonColor  = false
    nub.ZIndex           = 2
    corner(7, nub)
    stroke(1.5, Color3.fromRGB(15,15,15), nub)

    local sliding = false
    nub.MouseButton1Down:Connect(function() sliding = true end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = (i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
            rel = math.clamp(rel, 0, 1)
            local val = math.floor(min + rel*(max-min))
            valLbl.Text = tostring(val)
            fill.Size   = UDim2.new(rel,0,1,0)
            nub.Position = UDim2.new(rel,0,0.5,-7)
            onChange(val)
        end
    end)

    return row
end

