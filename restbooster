-- Master Configuration
local CONFIG_FILE = "RestHubBooster_Config.json"
local CONFIG = {
    GUI_POSITION = {X = 0.5, Y = 0.5},
    SPEED = {Normal = 16, Stealing = 50}
}

local function LoadConfig()
    if isfile and isfile(CONFIG_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
        if success and data then
            CONFIG.GUI_POSITION = data.GUI_POSITION or CONFIG.GUI_POSITION
            CONFIG.SPEED = data.SPEED or CONFIG.SPEED
        end
    end
end

local function SaveConfig()
    if writefile then
        pcall(function() writefile(CONFIG_FILE, HttpService:JSONEncode(CONFIG)) end)
    end
end

