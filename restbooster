-- UI Helper Function with Hotbar Fix
local function createInput(yPos, labelText, defaultValue)
    local label = Instance.new("TextLabel", MainFrame)
    label.Size = UDim2.new(0, 190, 0, 15)
    label.Position = UDim2.new(0, 15, 0, yPos)
    label.Text = labelText
    label.Font = Enum.Font.GothamSemibold
    label.TextSize = 12
    label.TextColor3 = Color3.fromRGB(200, 255, 200)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left

    local box = Instance.new("TextBox", MainFrame)
    box.Size = UDim2.new(0, 190, 0, 25)
    box.Position = UDim2.new(0, 15, 0, yPos + 18)
    box.Text = tostring(defaultValue)
    box.Font = Enum.Font.Gotham
    box.BackgroundColor3 = Color3.fromRGB(0, 30, 15)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", box).Color = Color3.fromRGB(0, 255, 100)
    
    -- Strip non-numbers
    box:GetPropertyChangedSignal("Text"):Connect(function()
        box.Text = box.Text:gsub("%D+", "")
    end)

    -- HOTBAR FIX: Disable backpack when typing so numbers don't equip items
    box.Focused:Connect(function()
        pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false) end)
    end)
    box.FocusLost:Connect(function()
        pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true) end)
    end)

    return box
end

