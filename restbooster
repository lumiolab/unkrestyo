-- Improved Anti-Rubberband Velocity Loop
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    -- Only override physics if a custom speed is active
    if hum and root and activeSpeed > 16 then
        if hum.MoveDirection.Magnitude > 0 then
            -- Apply direct velocity based on camera direction
            local targetVelocity = hum.MoveDirection * activeSpeed
            root.AssemblyLinearVelocity = Vector3.new(targetVelocity.X, root.AssemblyLinearVelocity.Y, targetVelocity.Z)
        else
            -- ANTI-RUBBERBAND FIX: Kill momentum instantly when you stop pressing keys
            root.AssemblyLinearVelocity = Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
        end
    end
end)

